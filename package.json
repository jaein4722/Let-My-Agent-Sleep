{
  "name": "lmas-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "pack": "npm_config_cache=${TMPDIR:-/tmp}/lmas-npm-cache npm pack --workspace let-my-agent-sleep --dry-run",
    "release:check": "bash tests/release/check.sh",
    "test:site": "tests/site/check-site.py",
    "test:smoke": "tests/smoke/run.sh"
  }
}
